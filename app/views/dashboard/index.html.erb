<h1>Dashboard</h1>

<% @categories.each do |category| %>
  <div style="margin-bottom: 20px;">
    <h2><%= category.name %></h2>

    <ul>
      <% category.links.each do |link| %>
        <li>
          <a href="<%= link.url %>" target="_blank">
            <%= link.name %>
          </a>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>