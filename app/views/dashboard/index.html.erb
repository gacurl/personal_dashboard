<!-- app/views/dashboard/index.html.erb -->
<div class="dashboard-shell">
  <div class="flight-plan-bar">
    <form class="flight-plan-bar__form" action="#" method="get">
      <label for="flight-plan-search" class="sr-only">Search Flight Plan</label>
      <input
        id="flight-plan-search"
        name="q"
        type="search"
        class="flight-plan-bar__input"
        placeholder="Search Flight Plan"
        autocomplete="off"
      />
    </form>

    <div class="flight-plan-bar__actions">
      <%= link_to "+ Category", new_category_path, class: "btn btn--secondary" %>
    </div>
  </div>

  <header class="dashboard-header">
    <h1 class="dashboard-title">Flight Deck Control</h1>
    <p class="dashboard-subtitle">Your daily links, prepped, set, and ready for launch</p>
  </header>

  <section class="category-grid">
    <% @categories.each do |category| %>
      <section class="category-card" data-searchable-category>
        <div class="category-card__header">
          <h2 class="category-card__title"><%= category.name %></h2>
          <%= link_to "+ Add", new_link_path(category_id: category.id), class: "card-add-btn" %>
        </div>

        <% if category.links.any? %>
          <ul class="link-list">
            <% category.links.each do |link| %>
              <li 
                class="link-list__item"
                data-searchable-item
                data-name="<%= link.name.to_s.downcase %>" 
                data-url="<%= link.url.to_s.downcase %>"
              >
                <%= link_to link.url, target: "_blank", rel: "noopener", class: "link-card" do %>
                  <h3><%= link.name %></h3>
                  <p><%= link.url %></p>
                <% end %>
                <div class="link-card__actions">
                  <%= link_to "Edit", edit_link_path(link), class: "link-manage-link" %>
                  <%= link_to "Delete", link_path(link),
                    data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                    class: "link-manage-link link-manage-link--danger" %>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="empty-state">
            No links yet.
            <%= link_to "Add first link", new_link_path(category_id: category.id), class: "empty-cta" %>
          </div>
        <% end %>
      </section>
    <% end %>
  </section>

  <section class="schedule-panel">
    <div class="schedule-panel__header">
      <div>
        <h2 class="schedule-panel__title">Today’s Flight Schedule</h2>
        <p class="schedule-panel__subtitle">Upcoming events and key timing for today</p>
      </div>
      
      <%= link_to "+ Schedule", new_schedule_item_path, class: "btn btn--secondary" %>
    </div>

    <div class="schedule-panel__body">
      <% if @schedule_items.any? %>
        <ul class="schedule-list">
          <% @schedule_items.each do |item| %>
            <li class="schedule-item">
              <span class="schedule-time"><%= item.start_time.strftime("%H%M") %></span>

              <div class="schedule-item__content">
                <span class="schedule-event"><%= item.title %></span>

                <% if item.notes.present? %>
                  <p class="schedule-notes"><%= item.notes %></p>
                <% end %>
              </div>

              <div class="schedule-item__actions">
                <%= link_to "Edit", edit_schedule_item_path(item), class: "link-manage-link" %>
                <%= link_to "Delete", schedule_item_path(item),
                  data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                  class: "link-manage-link link-manage-link--danger" %>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="schedule-panel__empty">
          No schedule items for today.
          <%= link_to "Add schedule item", new_schedule_item_path, class: "empty-cta" %>
        </div>
      <% end %>

      <div class="schedule-panel__section">
        <h3 class="schedule-panel__section-title">Upcoming</h3>

        <% if @upcoming_schedule_items.any? %>
          <ul class="schedule-list">
            <% @upcoming_schedule_items.each do |item| %>
              <li class="schedule-item">
                <span class="schedule-time"><%= item.start_time.strftime("%m/%d") %></span>

                <div class="schedule-item__content">
                  <span class="schedule-event">
                    <%= item.start_time.strftime("%H%M") %> — <%= item.title %>
                  </span>

                  <% if item.notes.present? %>
                    <p class="schedule-notes"><%= item.notes %></p>
                  <% end %>
                </div>

                <div class="schedule-item__actions">
                  <%= link_to "Edit", edit_schedule_item_path(item), class: "link-manage-link" %>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="schedule-panel__empty">
            No upcoming schedule items.
          </div>
        <% end %>
    </div>
  </div>
  </section>
</div>