<!-- app/views/dashboard/index.html.erb -->
<div class="dashboard-shell">
  <div class="top-bar">
    <div class="top-bar__brand">LINKDASH</div>

    <div class="top-bar__actions">
      <%= link_to "+ Link", new_link_path, class: "btn btn--primary" %>
      <%= link_to "+ Category", new_category_path, class: "btn btn--secondary" %>
    </div>
  </div>
  
  <header class="dashboard-header">
    <h1 class="dashboard-title">The Lobby</h1>
    <p class="dashboard-subtitle">Your daily links, organized and close at hand.</p>
  </header>

  <main class="category-grid">
    <% @categories.each do |category| %>
      <section class="category-card">
        <div class="category-card__header">
          <h2 class="category-card__title"><%= category.name %></h2>
          <span class="category-card__count"><%= pluralize(category.links.count, "link") %></span>
        </div>

        <% if category.links.any? %>
          <ul class="link-list">
            <% category.links.each do |link| %>
              <li class="link-list__item">
                <a class="dashboard-link" href="<%= link.url %>" target="_blank" rel="noopener">
                  <span class="dashboard-link__name"><%= link.name %></span>
                  <span class="dashboard-link__url"><%= link.url %></span>
                </a>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="empty-state">No links yet.</p>
        <% end %>
      </section>
    <% end %>
  </main>
</div>